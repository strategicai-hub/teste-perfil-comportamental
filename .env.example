# Portainer
PORTAINER_URL=https://91.98.64.92:9443
PORTAINER_TOKEN=your_portainer_token_here

# GitHub (for GHCR push)
GITHUB_USER=strategicai-hub
GITHUB_TOKEN=your_github_token_here

# Application
PUBLIC_BASE_URL=https://teste.strategicai.com.br/perfil-comportamental
BASE_PATH=/perfil-comportamental
DATABASE_URL=sqlite:////data/app.db

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Google Sheets
GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
GOOGLE_SHEET_ID=your_sheet_id_here

# SMTP (Gmail/Google Workspace)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@domain.com
SMTP_PASS=your_app_password_here
SMTP_FROM=your_email@domain.com

# UAZAPI (WhatsApp notifications)
UAZAPI_BASE_URL=https://strategicai.uazapi.com
UAZAPI_TOKEN=your_uazapi_token_here
UAZAPI_INSTANCE=your_instance_name
ALERT_PHONE=55your_phone_number

# Admin panel (/admin)
ADMIN_USER=admin@strategicai.com.br
ADMIN_PASS=changeme

# JWT (deixe vazio para gerar automaticamente em runtime — em produção defina um valor fixo)
JWT_SECRET=
JWT_EXPIRE_HOURS=24
